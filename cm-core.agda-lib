name: cm-core-0.1.0
include: src extra
depend:
flags:
  --cubical=erased
  --erasure
  --exact-split
  --experimental-lazy-instances
  --guardedness
  --hidden-argument-puns
  --postfix-projections
  --safe

  --no-import-sorts
  --no-prop
  --no-qualified-instances
  --no-sized-types

  -Werror
  -WnoUnsupportedIndexedMatch
