name: cm-core-0.1.0
include: src
depend:
flags:
  --cubical=erased
  --erased-matches
  --erasure
  --exact-split
  --experimental-lazy-instances
  --guardedness
  --hidden-argument-puns
  --postfix-projections
  --safe

  --no-import-sorts
  --no-prop
  --no-qualified-instances

  -Werror
  -WnoUnsupportedIndexedMatch
